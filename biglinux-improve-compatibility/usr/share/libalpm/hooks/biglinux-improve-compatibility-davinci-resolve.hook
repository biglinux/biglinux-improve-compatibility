[Trigger]
Type = Package
Operation = Install
Operation = Upgrade
Target = davinci-resolve
Target = biglinux-improve-compatibility

[Action]
Description = Applying modifications to make Davinci Resolve compatible
When = PostTransaction
Exec = /bin/sh -c 'if [ -d /opt/resolve/libs ]; then rm -f /opt/resolve/libs/libglib-2.0.so* /opt/resolve/libs/libgio-2.0.so* /opt/resolve/libs/libgmodule-2.0.so*; fi'
