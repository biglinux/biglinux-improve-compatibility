[Trigger]
Type = Package
Operation = Remove
Target = pcsclite

[Action]
Description = Auto disable pcsclite before remove
When = PreTransaction
Exec = /bin/sh -c '{ [ -e /usr/lib/systemd/system/pcscd.service ] || [ -e /etc/systemd/system/pcscd.service ]; } && systemctl disable pcscd > /dev/null 2>&1'
